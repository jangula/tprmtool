<%- include('layout', { body: `
<div class="min-vh-100 d-flex align-items-center justify-content-center" style="background: linear-gradient(135deg, #1e3a5f 0%, #0f172a 100%);">
  <div class="card shadow-lg" style="width: 400px; border-radius: 16px;">
    <div class="card-body p-5">
      <div class="text-center mb-4">
        <div class="mb-3">
          <i class="bi bi-shield-check" style="font-size: 3rem; color: #2563eb;"></i>
        </div>
        <h3 class="fw-bold">TPRM Tool</h3>
        <p class="text-muted">Third Party Risk Management Training</p>
      </div>

      ${error ? '<div class="alert alert-danger">' + error + '</div>' : ''}

      <form method="POST" action="/login">
        <div class="mb-3">
          <label class="form-label">Email Address</label>
          <input type="email" name="email" class="form-control form-control-lg" required placeholder="you@example.com">
        </div>

        <div class="mb-4">
          <label class="form-label">Password</label>
          <input type="password" name="password" class="form-control form-control-lg" required placeholder="Enter password">
        </div>

        <button type="submit" class="btn btn-primary btn-lg w-100 mb-3">
          <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
        </button>
      </form>

      <div class="text-center">
        <span class="text-muted">Don't have an account?</span>
        <a href="/register" class="text-decoration-none fw-semibold">Register</a>
      </div>
    </div>
  </div>
</div>
` }) %>
